{
  "name": "chai-choco-tailwind",
  "version": "2.0.1",
  "description": "A chocolate-themed runtime CSS utility engine. Drop in a script tag — no build step needed.",
  "private": false,
  "type": "module",
  "main": "./dist/chai-choco-tailwind.umd.js",
  "module": "./dist/chai-choco-tailwind.esm.js",
  "exports": {
    ".": {
      "import": "./dist/chai-choco-tailwind.esm.js",
      "require": "./dist/chai-choco-tailwind.umd.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "css",
    "tailwind",
    "utility",
    "runtime",
    "chocolate",
    "theme",
    "jit",
    "no-build",
    "choco"
  ],
  "author": "Saurabh Prajapati",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "clean": "rm -rf dist",
    "build": "npm run clean && vite build",
    "preview": "vite preview",
    "pack": "npm pack"
  },
  "devDependencies": {
    "vite": "^8.0.1"
  }
}
